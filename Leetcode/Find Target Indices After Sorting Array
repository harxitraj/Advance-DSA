class Solution {
    public List<Integer> targetIndices(int[] nums, int target) {
        int countSmaller = 0;
        int countTarget = 0;
        List<Integer> ans = new ArrayList<>();
        
        for(int num : nums) {
            if(num < target) {
                countSmaller++;
            } else if(num == target) {
                countTarget++;
            }
        }
        for(int i = 0; i < countTarget; i++) {
            ans.add(countSmaller + i);
        }
        return ans;
    }
}
