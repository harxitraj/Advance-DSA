class Solution {
    public boolean canJump(int[] nums) {
        int n = nums.length;
        int finalPosition = n - 1;
        for(int idx = n-2; idx >= 0; idx--) {
            if(idx + nums[idx] >= finalPosition) {
                finalPosition = idx;
            }
        }
        return finalPosition == 0;
    }
}
