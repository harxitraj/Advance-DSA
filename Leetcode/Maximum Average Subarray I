class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;
        int subSum = 0;
        for (int i = 0; i < k; i++) {
            subSum += nums[i];
        }
        int maxSum = subSum;
        
        for (int i = k; i < n; i++) {
            subSum += nums[i];
            subSum -= nums[i - k];
            maxSum = Math.max(maxSum, subSum);
        }
        return (double) maxSum / k;
    }
}
