class Solution {
    public int minAddToMakeValid(String s) {
        int n = s.length();
        int balance = 0;
        int moves = 0;

        for(int i = 0; i < n; i++) {
            char ch = s.charAt(i);
            if(ch == '(') {
                balance++;
            } else {
                if(balance > 0) {
                    balance--;
                } else {
                    moves++;
                }
            }
        }
        return moves + balance;
    }
}
