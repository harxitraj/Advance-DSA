class Solution {
    public int minimumDistance(String word) {
        int n = word.length();
        Integer[][][] dp = new Integer[n][27][27];
        return solve(word, 0, -1, -1, dp);
    }
    
    private static int solve(String word, int i, int f1, int f2, Integer[][][] dp) {
        if (i == word.length()) {
            return 0;
        }
        if (dp[i][f1 + 1][f2 + 1] != null) {
            return dp[i][f1 + 1][f2 + 1];
        }
        int curr = word.charAt(i) - 'A';
        int cost1 = getDist(f1, curr) + solve(word, i + 1, curr, f2, dp);
        int cost2 = getDist(f2, curr) + solve(word, i + 1, f1, curr, dp);
        
        return dp[i][f1 + 1][f2 + 1] = Math.min(cost1, cost2);
    }
    
    private static int getDist(int a, int b) {
        if (a == -1) {
            return 0;
        }
        int x1 = a / 6, y1 = a % 6;
        int x2 = b / 6, y2 = b % 6;
        
        return Math.abs(x1 - x2) + Math.abs(y1 - y2);
    }
}
