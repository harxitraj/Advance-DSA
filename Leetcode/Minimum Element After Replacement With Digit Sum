class Solution {
    public int minElement(int[] nums) {
        int n = nums.length;
        int minSum = Integer.MAX_VALUE;
        for(int i = 0; i < n; i++) {
            int digitSum = 0;
            int curr = nums[i];
            while(curr != 0) {
                digitSum += curr % 10;
                curr /= 10;
            }
            if(digitSum < minSum) {
                minSum = digitSum;
            }
        }
        return minSum;
    }
}
