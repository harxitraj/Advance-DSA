class Solution {
    public int minPatches(int[] nums, int n) {
        long reach = 0;
        int patches = 0;
        int idx = 0;

        while(reach < n) {
            if(idx < nums.length && nums[idx] <= reach + 1) {
                reach += nums[idx];
                idx++;
            } else {
                long patch = reach + 1;
                reach += patch;
                patches++;
            }
        }
        return patches;
    }
}
