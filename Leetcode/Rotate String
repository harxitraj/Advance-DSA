class Solution {
    public boolean rotateString(String s, String goal) {
        int m = s.length();
        int n = goal.length();
        if(m != n) {
            return false;
        }
        for(int i = 0; i < n; i++) {
            char ch = s.charAt(i);
            s = s + ch;
            String curr = s.substring(i+1, s.length());
            if(curr.equals(goal)) {
                return true;
            }
        }
        return false;
    }
}
